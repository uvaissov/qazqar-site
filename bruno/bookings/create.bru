meta {
  name: Create booking
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/bookings
  body: json
  auth: none
}

body:json {
  {
    "carId": "{{carId}}",
    "customerName": "Иван Иванов",
    "customerPhone": "+77001234567",
    "customerEmail": "user@example.com",
    "startDate": "2026-04-20 10:00",
    "endDate": "2026-04-25 10:00",
    "comment": "Тест",
    "isResident": true
  }
}
