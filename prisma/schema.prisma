generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(cuid())
  email          String?         @unique
  phone          String?         @unique
  passwordHash   String
  firstName      String
  lastName       String
  role           UserRole        @default(CLIENT)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  clientId       Int?
  iin            String?
  isResident     Boolean         @default(true)
  blogPosts      BlogPost[]
  bookings       Booking[]
  remoteCommands RemoteCommand[]

  @@map("users")
}

model CarBrand {
  id     String     @id @default(cuid())
  name   String     @unique
  slug   String     @unique
  logo   String?
  models CarModel[]

  @@map("car_brands")
}

model CarModel {
  id      String   @id @default(cuid())
  name    String
  slug    String   @unique
  brandId String
  brand   CarBrand @relation(fields: [brandId], references: [id])
  cars    Car[]

  @@map("car_models")
}

model Car {
  id            String       @id @default(cuid())
  modelId       String
  year          Int
  color         String
  pricePerDay   Int          @default(15000)
  transmission  Transmission @default(AUTOMATIC)
  fuelType      FuelType     @default(AI92)
  seats         Int          @default(5)
  hasAC         Boolean      @default(true)
  status        CarStatus    @default(AVAILABLE)
  slug          String       @unique
  descriptionRu String?
  descriptionKz String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  availableFrom DateTime?
  inventoryId   Int          @unique
  nextBookingAt DateTime?
  number        String       @unique
  techPassport  String?
  totalDistance Int          @default(0)
  vin           String?
  deposit       Int          @default(0)
  hasRemote     Boolean      @default(false)
  remotePhone   String?
  bookings      Booking[]
  photos        CarPhoto[]
  model         CarModel     @relation(fields: [modelId], references: [id])

  @@map("cars")
}

model Photo {
  id        String     @id @default(cuid())
  url       String     @unique
  name      String?
  createdAt DateTime   @default(now())
  cars      CarPhoto[]

  @@map("photos")
}

model CarPhoto {
  carId     String
  photoId   String
  sortOrder Int    @default(0)
  car       Car    @relation(fields: [carId], references: [id], onDelete: Cascade)
  photo     Photo  @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@id([carId, photoId])
  @@map("car_photos")
}

model Booking {
  id                 String          @id @default(cuid())
  userId             String?
  carId              String
  startDate          DateTime
  endDate            DateTime
  totalPrice         Int
  discountPercent    Int             @default(0)
  status             BookingStatus   @default(PENDING)
  customerName       String
  customerPhone      String
  comment            String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  cancellationReason String?
  documents          Json?
  pickupDocuments    Json?
  depositAmount      Int?
  depositLabel       String?
  withDeposit        Boolean         @default(true)
  requestId          Int?            @unique
  pickupAddressId    String?
  returnAddressId    String?
  car                Car             @relation(fields: [carId], references: [id])
  pickupAddress      Address?        @relation("PickupAddress", fields: [pickupAddressId], references: [id])
  returnAddress      Address?        @relation("ReturnAddress", fields: [returnAddressId], references: [id])
  user               User?           @relation(fields: [userId], references: [id])
  remoteCommands     RemoteCommand[]

  @@map("bookings")
}

model BlogPost {
  id         String   @id @default(cuid())
  slug       String   @unique
  titleRu    String
  titleKz    String   @default("")
  contentRu  String
  contentKz  String   @default("")
  coverImage String?
  published  Boolean  @default(false)
  authorId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  author     User     @relation(fields: [authorId], references: [id])

  @@map("blog_posts")
}

model Review {
  id         String   @id @default(cuid())
  authorName String
  rating     Int
  textRu     String
  textKz     String   @default("")
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@map("reviews")
}

model Discount {
  id      String  @id @default(cuid())
  minDays Int
  maxDays Int
  percent Int
  active  Boolean @default(true)

  @@map("discounts")
}

model NoDepositSurcharge {
  id      String @id @default(cuid())
  minDay  Int
  maxDay  Int
  percent Float

  @@map("no_deposit_surcharges")
}

model AppSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("app_settings")
}

model FaqItem {
  id         String  @id @default(cuid())
  sortOrder  Int     @default(0)
  questionRu String
  questionKz String  @default("")
  answerRu   String
  answerKz   String  @default("")
  published  Boolean @default(true)

  @@map("faq_items")
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  type      OtpType
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, code, type])
  @@map("otp_codes")
}

model Address {
  id             String    @id @default(cuid())
  name           String
  address        String
  lat            Float?
  lng            Float?
  isActive       Boolean   @default(true)
  sortOrder      Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  pickupBookings Booking[] @relation("PickupAddress")
  returnBookings Booking[] @relation("ReturnAddress")

  @@map("addresses")
}

enum UserRole {
  CLIENT
  ADMIN
}

enum CarStatus {
  AVAILABLE
  RENTED
  MAINTENANCE
}

enum Transmission {
  AUTOMATIC
  MANUAL
}

enum FuelType {
  AI92
  AI95
  AI98
  DIESEL
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ACTIVE
  RETURN_PENDING
  COMPLETED
  CANCELLED
}

enum RemoteAction {
  UNLOCK
  LOCK
}

model RemoteCommand {
  id          String       @id @default(cuid())
  bookingId   String
  userId      String
  action      RemoteAction
  targetPhone String
  smsText     String
  providerId  String?
  ok          Boolean      @default(true)
  error       String?
  createdAt   DateTime     @default(now())
  booking     Booking      @relation(fields: [bookingId], references: [id])
  user        User         @relation(fields: [userId], references: [id])

  @@index([bookingId, createdAt])
  @@index([userId, createdAt])
  @@map("remote_commands")
}

enum OtpType {
  REGISTER
  RESET_PASSWORD
  LOGIN
}
